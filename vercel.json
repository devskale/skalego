{
  "framework": "astro",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/firmenindex/api", "destination": "/api/firmenindex-api" },
    { "source": "/credgoo", "destination": "/api/credgoo" },
    { "source": "/uniinfer", "destination": "/api/uniinfer" },
    { "source": "/chopdok", "destination": "https://chopdok.vercel.app/chopdok" },
    { "source": "/chopdok/:path*", "destination": "https://chopdok.vercel.app/chopdok/:path*" },
    { "source": "/pdf-editor", "destination": "https://pdf-editor-rouge-psi.vercel.app/" },
    { "source": "/pdf-editor/:path*", "destination": "https://pdf-editor-rouge-psi.vercel.app/:path*" }
  ],
  "redirects": [
    { "source": "/apps.html", "destination": "/apps/", "permanent": true },
    { "source": "/impressum.html", "destination": "/impressum/", "permanent": true },
    { "source": "/datenschutz.html", "destination": "/datenschutz/", "permanent": true },
    { "source": "/tos.html", "destination": "/tos/", "permanent": true },
    { "source": "/agent-coding.html", "destination": "/agent-coding/", "permanent": true },
    { "source": "/meet", "destination": "https://meet.google.com/uti-zsep-efw", "permanent": true },
    { "source": "/agentsmd", "destination": "https://github.com/devskale/skale-skills/blob/main/docs/agents-md-best-practices.md", "permanent": true },
    { "source": "/agentskills", "destination": "https://github.com/devskale/skale-skills/blob/main/docs/agent-skills-best-practices.md", "permanent": true },
    { "source": "/piextensions", "destination": "https://github.com/devskale/skale-skills/blob/main/docs/pi-extensions-best-practices.md", "permanent": true }
  ]
}
