{
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/firmenindex/api/:path*", "destination": "/api/firmenindex/:path*" }
  ],
  "redirects": [
    { "source": "/meet", "destination": "https://meet.google.com/uti-zsep-efw", "permanent": true }
  ]
}
