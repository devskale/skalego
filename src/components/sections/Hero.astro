---
// Hero — particle canvas + headline. Canvas id drives site.js.
---

<section id="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <canvas id="hero-canvas" aria-hidden="true"></canvas>
  <div class="hero-content">
    <div class="hero-badge reveal">AI Engineering</div>
    <h1 class="hero-title reveal">
      Individuelle KI-Systeme für <span class="accent">Unternehmen</span>.
    </h1>
    <p class="hero-sub reveal">
      KI auf Ihre Prozesse abgestimmt, lokal und on-premise
      betrieben. Ihre Daten bleiben, wo sie sind. Ihr Lernen
      gehört Ihnen.
    </p>
    <div class="hero-actions reveal">
      <a href="/#contact" class="btn btn-primary btn-lg">Erstgespräch vereinbaren</a>
      <a href="/#services" class="btn btn-outline">Services ansehen</a>
    </div>
  </div>
</section>
