---
import BaseLayout from '@layouts/BaseLayout.astro';

const apps = [
  {
    href: '/firmenindex/',
    shot: '/logos/screenshot-firmenindex.png',
    alt: 'Firmenindex Österreich',
    iconClass: 'red',
    icon: 'FI',
    name: 'Firmenindex Österreich',
    desc: 'Firmensuche für Österreich mit über 40.000 Unternehmen. Suche nach Firma, Firmenbuchnummer (FN), Person oder Branche. Durchsucht den gecrawlten Cache in Echtzeit.',
    tags: ['Österreich', 'FN-Suche', 'Branchen', 'Open Data'],
  },
  {
    href: '/pdf-editor',
    shot: '/logos/screenshot-pdfeditor.png',
    alt: 'PDF Annotator',
    iconClass: 'blue',
    icon: 'PD',
    name: 'PDF Annotator',
    desc: 'PDF-Dokumente direkt im Browser annotieren und bearbeiten. Datei hochladen, Text hinzufügen, markieren und speichern — komplett client-seitig, ohne Server-Upload.',
    tags: ['PDF', 'Annotation', 'Browser', 'Client-seitig'],
  },
  {
    href: '/chopdok',
    shot: '/logos/screenshot-chopdok.png',
    alt: 'ChopDok',
    iconClass: 'green',
    icon: 'CD',
    name: 'ChopDok',
    desc: 'PDF-Seiten einfach aufteilen, extrahieren und neu anordnen. Drag-and-drop Upload, Seiten auswählen, neu zusammenfügen und herunterladen. Kostenlos, werbefrei, ohne Datenerfassung.',
    tags: ['PDF', 'Seiten', 'Browser', 'No Ads'],
  },
];

const arrow = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 13l5-5-5-5"/><path d="M12 8H2"/></svg>';

const jsonld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: 'https://skale.dev/' },
        { '@type': 'ListItem', position: 2, name: 'Apps & Tools', item: 'https://skale.dev/apps/' },
      ],
    },
    {
      '@type': 'CollectionPage',
      name: 'Apps & Tools – skale.dev',
      url: 'https://skale.dev/apps/',
      description: 'Kostenlose Web-Tools von skale.dev: Firmenindex Österreich, PDF Annotator, ChopDok.',
      isPartOf: { '@id': 'https://skale.dev/#website' },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: apps.map((a, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          item: {
            '@type': 'SoftwareApplication',
            name: a.name,
            applicationCategory: 'BusinessApplication',
            operatingSystem: 'Web',
            url: new URL(a.href, 'https://skale.dev/').toString(),
            description: a.desc,
            offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
            publisher: { '@id': 'https://skale.dev/#organization' },
          },
        })),
      },
    },
  ],
};

const title = 'Apps & Tools – skale.dev';
const description = 'Apps und Tools von skale.dev: Firmenindex Österreich, PDF Annotator, ChopDok – kostenlose Web-Tools für Unternehmen.';
---

<BaseLayout title={title} description={description} path="/apps/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  </Fragment>

  <section class="apps-page">
    <div class="container">
      <a href="/" class="apps-back">← Zurück zur Startseite</a>

      <header class="apps-head">
        <h1>Apps &amp; Tools</h1>
        <p>Kostenlose Web-Tools aus dem skale.dev-Labor. Einfach im Browser nutzen – keine Anmeldung erforderlich.</p>
      </header>

      <div class="app-list">
        {apps.map((a) => (
          <a href={a.href} class="app-card">
            <div class="app-shot"><img src={a.shot} alt={a.alt} loading="lazy" /></div>
            <div class="app-body">
              <div class="app-header">
                <div class={`app-icon ${a.iconClass}`}>{a.icon}</div>
                <div class="app-name">{a.name}</div>
              </div>
              <p class="app-desc">{a.desc}</p>
              <div class="app-tags">
                {a.tags.map((t) => <span class="app-tag">{t}</span>)}
              </div>
              <span class="app-cta">Öffnen <Fragment set:html={arrow} /></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .apps-page { padding: 120px 0 80px; }
  .apps-page .container { max-width: 960px; }

  .apps-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .apps-back:hover { color: var(--red); }

  .apps-head h1 {
    font-size: 2.4rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--text-bright);
    letter-spacing: -0.5px;
  }
  .apps-head p {
    font-size: 1.1rem;
    color: var(--text-dim);
    max-width: 540px;
    line-height: 1.6;
  }

  .app-list {
    display: grid;
    gap: 20px;
    margin-top: 3rem;
  }

  .app-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 220px 1fr auto;
    align-items: center;
    gap: 0;
  }
  @media (max-width: 640px) {
    .app-card { grid-template-columns: 1fr; }
  }
  .app-card:hover {
    border-color: rgba(229,57,53,0.35);
    transform: translateY(-2px);
  }

  .app-shot {
    width: 220px; height: 140px;
    overflow: hidden;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
    background: #111;
  }
  .app-shot img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top left;
    opacity: 0.85;
    transition: opacity 0.2s;
    display: block;
  }
  .app-card:hover .app-shot img { opacity: 1; }
  @media (max-width: 640px) {
    .app-shot { width: 100%; height: 160px; border-right: none; border-bottom: 1px solid var(--border); }
  }

  .app-body { padding: 22px 24px; min-width: 0; }
  .app-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .app-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.95rem; font-weight: 800;
    flex-shrink: 0;
  }
  .app-icon.red   { background: rgba(229,57,53,0.12); color: #e53935; }
  .app-icon.blue  { background: rgba(66,133,244,0.12); color: #4285f4; }
  .app-icon.green { background: rgba(76,175,80,0.12); color: #4caf50; }
  .app-name { font-size: 1.1rem; font-weight: 700; color: var(--text-bright); }
  .app-desc { font-size: 0.88rem; color: var(--text); line-height: 1.55; margin-bottom: 10px; }
  .app-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .app-tag {
    font-family: var(--mono);
    font-size: 0.68rem;
    padding: 2px 7px;
    border-radius: 5px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }

  .app-cta {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 18px 22px;
    font-size: 0.84rem; font-weight: 600;
    color: var(--red);
    white-space: nowrap;
    border-left: 1px solid var(--border);
    height: 100%;
    transition: background 0.2s;
  }
  @media (max-width: 640px) {
    .app-cta { border-left: none; border-top: 1px solid var(--border); padding: 14px; }
  }
  .app-cta svg { width: 13px; height: 13px; transition: transform 0.2s; margin-left: 5px; }
  .app-card:hover .app-cta { background: rgba(229,57,53,0.06); }
  .app-card:hover .app-cta svg { transform: translateX(3px); }
</style>
