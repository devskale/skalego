---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// The "recommended-skills" blog entry's frontmatter `skills` array IS the registry.
// Edit that one blog post (Keystatic or markdown) → this list updates on next build.
const all = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true));
const entry = all.find((p) => Array.isArray(p.data.skills) && p.data.skills.length);
const skills = entry?.data.skills ?? [];

const title = 'Skills – skale.dev';
const description = 'One-line install for recommended agent skills: curl -fsSL skale.dev/s/<name> | bash';
---

<BaseLayout title={title} description={description} path="/skills/">
  <section class="skills">
    <div class="container">
      <header class="section-head reveal">
        <span class="hero-badge reveal">skale.dev / skills</span>
        <h2 class="section-title">One-line skill installs.</h2>
        <p class="section-sub">
          Each installs with <code>curl -fsSL skale.dev/s/&lt;name&gt; | bash</code>.
          Our own pi-skills enable via the package whitelist; external ones run their upstream installer.
        </p>
      </header>

      <ul class="skill-grid">
        {skills.map((s) => {
          const cmd = `curl -fsSL https://skale.dev/s/${s.slug} | bash`;
          return (
            <li class="skill-card reveal">
              <h3 class="skill-card__title">{s.slug}</h3>
              <p class="skill-card__desc">{s.desc}</p>
              <div class="install-box"><code>{cmd}</code></div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .skills { padding: 7rem 0 6rem; }
  .skill-grid { list-style: none; padding: 0; margin: 3rem 0 0; display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); }
  .skill-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 1.5rem; display: flex; flex-direction: column; gap: 0.85rem; }
  .skill-card__title { font-family: 'JetBrains Mono', monospace; font-size: 1.15rem; font-weight: 600; color: var(--fg, #fff); margin: 0; }
  .skill-card__desc { color: var(--muted, #aab); font-size: 0.92rem; line-height: 1.5; margin: 0; flex: 1; }
  .install-box { background: #050506; border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 0.7rem 0.85rem; overflow-x: auto; }
  .install-box code { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #7fe7c1; white-space: nowrap; }
</style>
