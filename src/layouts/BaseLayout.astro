---
import '@styles/global.css';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** override canonical/OG path; defaults to current pathname */
  path?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Individuelle KI-Systeme für Unternehmen – on-premise, DSGVO-konform und produktionsreif. AI Engineering aus Österreich. Ihre Daten und Ihr Lernen bleiben im Haus.',
  path,
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://skale.dev');
const pathname = path ?? Astro.url.pathname;
const canonical = new URL(pathname, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();
const robots = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1';
---

<!doctype html>
<html lang="de-AT" data-color-scheme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="DI Johann Waldherr – skale.dev" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#08080a" />
    <link rel="canonical" href={canonical} />

    <!-- Icons / PWA -->
    <link rel="icon" type="image/png" href="/logos/skalelogo_red_trans.png" />
    <link rel="apple-touch-icon" href="/logos/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="skale.dev" />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Self-hosted fonts (DSGVO: no third-party CDN). Preload the two above-fold-critical weights. -->
    <link rel="preload" href="/fonts/inter-tight-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />

    <!-- gate scroll-reveal animations to JS-enabled clients (matches original) -->
    <script is:inline>document.documentElement.classList.add('js')</script>

    <!-- per-page JSON-LD / extra head content -->
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <div class="nav-sentinel" aria-hidden="true"></div>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <script>
      import '../scripts/site.js';
    </script>
    <noscript><style>.reveal{opacity:1!important;transform:none!important}</style></noscript>
  </body>
</html>
